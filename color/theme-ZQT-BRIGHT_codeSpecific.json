{
	"$schema": "vscode://schemas/color-theme",
	"name": "Specific Code Highlight - ZQT BRIGHT Theme",
	"//description": "各个语言专有的代码高亮",
	"include": "theme-ZQT-BRIGHT_codeUniversal.json",
	"tokenColors": [
		{
			"scope": [
				"entity.name.tag",
				"entity.name.tag.css"
			],
			"settings": {
				"foreground": "#856b1b"
			}
		},
		{
			"scope": [
				"entity.name.tag.custom"
			],
			"settings": {
				"foreground": "#907000"
			}
		},
		{
			"scope": "keyword.other.important.css",
			"settings": {
				"foreground": "#c13425"
			}
		},
		{
			"scope": [
				"punctuation.definition.heading.markdown",
				"punctuation.definition.bold.markdown",
				"punctuation.definition.raw.markdown",
				"punctuation.definition.markdown",
				"punctuation.definition.table.markdown",
				"punctuation.separator.table.markdown",
				"punctuation.definition.list.begin.markdown",
				"punctuation.definition.metadata.markdown",
				"punctuation.definition.link.title.begin.markdown",
				"punctuation.definition.link.title.end.markdown",
				"fenced_code.block.language.markdown",
				"markup.underline.link.markdown"
			],
			"settings": {
				"foreground": "#bebebe"
			}
		},
		{
			"scope": [
				"meta.separator.markdown"
			],
			"settings": {
				"foreground": "#808080"
			}
		},
		{
			"scope": "heading.1.markdown",
			"settings": {
				"foreground": "#cd3e62"
			}
		},
		{
			"scope": "heading.2.markdown",
			"settings": {
				"foreground": "#c0434c"
			}
		},
		{
			"scope": "heading.3.markdown",
			"settings": {
				"foreground": "#b1483a"
			}
		},
		{
			"scope": "heading.4.markdown",
			"settings": {
				"foreground": "#a14d2f"
			}
		},
		{
			"scope": "heading.5.markdown",
			"settings": {
				"foreground": "#90502a"
			}
		},
		{
			"scope": "markup.bold.markdown",
			"settings": {
				"foreground": "#6e519d"
			}
		},
		{
			"scope": [
				"markup.inline.raw.string.markdown",
				"markup.fenced_code.block.markdown"
			],
			"settings": {
				"foreground": "#277a55"
			}
		},
		{
			"scope": "markup.table.markdown",
			"settings": {
				"foreground": "#776a15"
			}
		},
		{
			"scope": "string.other.link.title.markdown",
			"settings": {
				"foreground": "#27709c"
			}
		}
	]
}